              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/auth/register",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"tenant\"\n}"
